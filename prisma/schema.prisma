// prisma/schema.prisma
generator client { provider = "prisma-client-js" }
datasource db { provider = "postgresql"; url = env("DATABASE_URL") }

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  password  String
  name      String
  phone     String?
  role      String   @default("user") // user|store|admin
  orders    Order[]
  favorites Favorite[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Store {
  id          String   @id @default(cuid())
  storeCode   String   @unique // 001..999
  username    String   @unique
  password    String
  name        String
  location    String?
  description String?
  businessHours String?
  phone       String?
  email       String?
  isDisabled  Boolean  @default(false)
  items       FoodItem[]
  orders      Order[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model FoodItem {
  id            String   @id @default(cuid())
  storeId       String
  store         Store    @relation(fields: [storeId], references: [id], onDelete: Cascade)
  name          String
  description   String?
  originalPrice Int
  discountPrice Int
  image         String?
  category      String?
  expiryTime    DateTime
  quantity      Int      @default(0)
  isListed      Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model Order {
  id            String   @id                           // order-001-YYYYMMDD-NNN
  userId        String
  user          User     @relation(fields: [userId], references: [id], onDelete: SetNull)
  storeId       String
  store         Store    @relation(fields: [storeId], references: [id], onDelete: SetNull)
  storeName     String
  storeLocation String?
  status        String   @default("pending")           // pending|accepted|prepared|completed|cancelled|rejected
  total         Int
  notes         String?
  customerName  String?
  customerPhone String?
  customerEmail String?
  items         OrderItem[]
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  acceptedAt    DateTime?
  preparedAt    DateTime?
  completedAt   DateTime?
  cancelledAt   DateTime?
  rejectedAt    DateTime?
  statusReason  String?
}

model OrderItem {
  id        String  @id @default(cuid())
  orderId   String
  order     Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  foodItemId String?
  name      String
  price     Int
  quantity  Int
  image     String?
}

model NewsItem {
  id        String   @id @default(cuid())
  title     String
  content   String
  storeId   String?
  store     Store?   @relation(fields: [storeId], references: [id], onDelete: SetNull)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Favorite {
  id      String @id @default(cuid())
  userId  String
  user    User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  storeId String
  store   Store  @relation(fields: [storeId], references: [id], onDelete: Cascade)
  @@unique([userId, storeId])
}

/** 同店家同日序號計數器，避免併發衝突 */
model OrderCounter {
  storeId String
  dateStr String
  seq     Int
  store   Store @relation(fields: [storeId], references: [id], onDelete: Cascade)

  @@id([storeId, dateStr])
  @@unique([storeId, dateStr])
}
